{
  "name": "OSX-MeisheVideo",
  "id": "OSX-MeisheVideo",
  "version": "1.0.0",
  "description": "美摄视频编辑与一键发布原生插件",
  "_dp_type": "nativeplugin",
  "_dp_nativeplugin": {
    "android": {
      "plugins": [
        {
          "type": "module",
          "name": "AThree-meishe2",
          "class": "com.malashequ.meishe.OSXMeisheVideoModule"
        }
      ],
      "minSdkVersion": "21",
      "dependencies": [
        "androidx.legacy:legacy-support-v4:1.0.0",
        "com.google.android.material:material:1.0.0",
        "androidx.appcompat:appcompat:1.0.0",
        "androidx.recyclerview:recyclerview:1.1.0",
        "androidx.constraintlayout:constraintlayout:1.1.3",
        "com.squareup.okhttp3:okhttp:3.11.0",
        "com.google.code.gson:gson:2.8.5",
        "com.github.bumptech.glide:glide:4.11.0",
        "com.zlc.glide:webpdecoder:1.4.4.9.0",
        "com.facebook.fresco:fresco:1.12.0",
        "com.facebook.soloader:soloader:0.10.4",
        "com.facebook.fresco:animated-gif:1.12.0",
        "com.facebook.fresco:animated-webp:1.12.0",
        "com.facebook.fresco:webpsupport:1.12.0",
        "androidx.multidex:multidex:2.0.0",
        "org.jetbrains.kotlin:kotlin-stdlib-jdk7:1.5.30",
        "org.jetbrains.kotlin:kotlin-reflect:1.5.30",
        {
          "source": "annotationProcessor 'androidx.lifecycle:lifecycle-compiler:2.2.0'"
        },
        "androidx.lifecycle:lifecycle-runtime-ktx:2.2.0",
        "androidx.lifecycle:lifecycle-extensions:2.2.0",
        "androidx.swiperefreshlayout:swiperefreshlayout:1.1.0",
        "com.google.dagger:dagger:2.24",
        {
          "source": "annotationProcessor 'com.google.dagger:dagger-compiler:2.24'"
        },
        "com.google.dagger:dagger-android:2.24",
        {
          "source": "annotationProcessor 'com.google.dagger:dagger-android-processor:2.24'"
        },
        "io.reactivex.rxjava2:rxandroid:2.1.1",
        "io.reactivex.rxjava2:rxjava:2.2.8",
        "androidx.viewpager2:viewpager2:1.0.0",
        "com.scwang.smart:refresh-layout-kernel:2.0.1",
        "com.scwang.smart:refresh-layout-horizontal:2.0.0",
        "com.scwang.smart:refresh-header-classics:2.0.1"
      ],
      "integrateType": "aar"
    },
    "ios": {
      "plugins": [
        {
          "type": "module",
          "name": "AThree-meishe2",
          "class": "OSXMeisheVideoModule"
        }
      ],
      "integrateType": "library",
      "frameworks": [
        "Frameworks/NvShortVideoCore.framework",
        "Frameworks/NvStreamingSdkCore.framework",
        "Frameworks/NvMSAICutter.framework",
        "Foundation.framework",
        "UIKit.framework",
        "Photos.framework",
        "AVFoundation.framework",
        "CoreMedia.framework",
        "CoreGraphics.framework",
        "MobileCoreServices.framework",
        "VideoToolbox.framework",
        "CoreVideo.framework",
        "Security.framework",
        "SystemConfiguration.framework"
      ],
      "embedFrameworks": [
        "Frameworks/NvShortVideoCore.framework",
        "Frameworks/NvStreamingSdkCore.framework",
        "Frameworks/NvMSAICutter.framework"
      ],
      "resources": [
        "BundleResources"
      ],
      "deploymentTarget": "12.0",
      "validArchitectures": [
        "arm64"
      ]
    }
  }
}
